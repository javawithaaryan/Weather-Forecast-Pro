# Weather Forecast Pro — Local Environment Configuration Template

# 🌤️ OpenWeatherMap API Key
# Sign up at https://openweathermap.org/api to get a free API key for weather telemetry.
VITE_OPENWEATHER_API_KEY=your_openweathermap_api_key

# 🤖 Google Gemini AI API Key
# Sign up at https://ai.google.dev/ to obtain a free Gemini 2.0 API key for the Weather X AI Assistant.
VITE_GEMINI_API_KEY=your_gemini_api_key
